// BinaCore Construction Project Management Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  projectCode String   @unique
  name        String
  description String?
  password    String?  // Optional password for project access
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  blocks      Block[]
  reports     Report[]
  issues      Issue[]
}

model Block {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  floors      Floor[]
}

model Floor {
  id                  String   @id @default(cuid())
  blockId             String
  floorNumber         Int
  floorName           String?
  notes               String?
  concreteDate        DateTime?
  concreteReview      String?
  groOeuvreProgress   Int      @default(0)
  cetProgress         Int      @default(0)
  cesProgress         Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  block       Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
}

model Report {
  id          String   @id @default(cuid())
  projectId   String
  type        String   // "PV_Visite" or "PV_Constat"
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AppSettings {
  id          String   @id @default(cuid())
  language    String   @default("en") // "en" or "fr" or "ar"
  theme       String   @default("light") // "light" or "dark"
  notifications Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Issue {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  type        String   @default("other") // "structural", "safety", "material", "quality", "other"
  severity    String   @default("medium") // "low", "medium", "high", "critical"
  status      String   @default("open") // "open", "in_progress", "resolved"
  floor       String?
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  updatedAt   DateTime @updatedAt

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
